# ─── NOTTEE9 Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/nottee9

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=nottee9_super_secret_jwt_key_change_in_production

# Server Port
PORT=5000

# Admin Credentials (used for initial seed)
ADMIN_EMAIL=admin@nottee9.in
ADMIN_PASSWORD=nottee9@admin

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
